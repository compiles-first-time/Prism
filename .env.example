# PRISM Development Environment Configuration
# Copy to .env and fill in values.

# PostgreSQL
DATABASE_URL=postgres://prism:prism_dev@localhost:5433/prism_dev
DATABASE_MAX_CONNECTIONS=10

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=prism_dev_neo4j

# Redis
REDIS_URL=redis://localhost:6380

# HashiCorp Vault (dev mode)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=prism-dev-root-token

# API Server
API_HOST=0.0.0.0
API_PORT=3000

# JWT
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
JWT_EXPIRY_SECONDS=3600

# Logging
RUST_LOG=prism_api=debug,prism_core=debug,tower_http=debug

# Environment
PRISM_ENV=dev
